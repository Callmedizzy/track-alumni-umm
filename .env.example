# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_DB=alumni_db
POSTGRES_USER=alumni_user
POSTGRES_PASSWORD=ganti_password_ini_dengan_yang_kuat

# Digunakan oleh FastAPI backend
DATABASE_URL=postgresql://alumni_user:ganti_password_ini_dengan_yang_kuat@db:5432/alumni_db

# ─────────────────────────────────────────────────────────────────────────────
# JWT Security
# ─────────────────────────────────────────────────────────────────────────────
# Generate dengan: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ganti-dengan-random-string-panjang-minimal-32-karakter

ACCESS_TOKEN_EXPIRE_HOURS=8

# ─────────────────────────────────────────────────────────────────────────────
# Frontend (React) - URL API backend
# ─────────────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
